{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "design_handoff_marysoll/ui_kits/app/**",
              "design_handoff_marysoll/ui_kits/landing/**",
              "design_handoff_marysoll/ui_kits/shared/**",
              "ui_kits/app/**",
              "ui_kits/landing/**",
              "ui_kits/listing/**",
              "ui_kits/shared/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Abril Fatface|Changa|Berkshire Swash))/i]",
        "message": "Font not provided by the design system. Available: Abril Fatface, Changa, Berkshire Swash."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
